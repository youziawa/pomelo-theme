<% if (page.total > 1) { %>
<nav class="pt-pagination" aria-label="Pagination">
  <% if (page.prev) { %>
    <a class="pt-pagination__btn pt-glass pt-glass--card" href="<%= url_for(page.prev_link) %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Prev
    </a>
  <% } %>

  <span class="pt-pagination__info"><%= page.current %> / <%= page.total %></span>

  <% if (page.next) { %>
    <a class="pt-pagination__btn pt-glass pt-glass--card" href="<%= url_for(page.next_link) %>">
      Next
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  <% } %>
</nav>
<% } %>
