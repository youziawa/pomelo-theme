<div class="pt-layout pt-layout--right-sidebar">
  <div class="pt-layout__content">
    <div class="pt-page-header">
      <h1 class="pt-page-header__title">
        <% if (page.category) { %>
          <%= page.category %>
        <% } else { %>
          <%= __('categories') %>
        <% } %>
      </h1>
    </div>

    <% if (page.category) { %>
      <!-- Posts for this category -->
      <div class="pt-card-grid">
        <% page.posts.each(function(post){ %>
          <article class="pt-post-card pt-glass pt-glass--card pt-glass--interactive">
            <a class="pt-post-card__link" href="<%= url_for(post.path) %>">
              <div class="pt-post-card__body">
                <h2 class="pt-post-card__title"><%= post.title %></h2>
                <div class="pt-post-card__meta">
                  <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
                </div>
              </div>
            </a>
          </article>
        <% }) %>
      </div>
      <%- partial('_partial/pagination', { page: page }) %>
    <% } else { %>
      <!-- Category List -->
      <div class="pt-category-list">
        <% site.categories.each(function(cat){ %>
          <a class="pt-category-card pt-glass pt-glass--card" href="<%= url_for(cat.path) %>">
            <span class="pt-category-card__name"><%= cat.name %></span>
            <span class="pt-category-card__count"><%= cat.posts.length %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>

  <aside class="pt-layout__sidebar">
    <%- partial('_partial/sidebar', { config: config, theme: theme, site: site }) %>
  </aside>
</div>
