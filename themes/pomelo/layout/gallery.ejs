<div class="pt-page-header">
  <h1 class="pt-page-header__title"><%= __('gallery') %></h1>
</div>

<div class="pt-gallery-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;">
  <% if (theme.gallery && theme.gallery.images && theme.gallery.images.length) { %>
    <% theme.gallery.images.forEach(function(img){ %>
      <a class="pt-gallery-item" href="<%= img.src %>" data-caption="<%= img.caption || '' %>" style="border-radius:8px;overflow:hidden;display:block;">
        <img src="<%= img.src %>" alt="<%= img.caption || '' %>" loading="lazy" style="width:100%;height:200px;object-fit:cover;border-radius:8px;">
      </a>
    <% }) %>
  <% } else { %>
    <p style="color:#9A9AB0;grid-column:1/-1;"><%= __('no_posts') %></p>
  <% } %>
</div>
