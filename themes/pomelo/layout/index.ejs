<!-- Homepage: Article List + Sidebar -->
<div class="pt-layout pt-layout--right-sidebar">
  <div class="pt-layout__content">
    <div class="pt-card-grid">
      <% page.posts.each(function(post){ %>
        <article class="pt-post-card pt-glass pt-glass--card pt-glass--interactive">
          <a class="pt-post-card__link" href="<%= url_for(post.path) %>">
            <% if (post.thumbnail || post.banner) { %>
              <div class="pt-post-card__cover">
                <img src="<%= url_for(post.thumbnail || post.banner) %>" alt="<%= post.title %>" loading="lazy">
              </div>
            <% } %>

            <div class="pt-post-card__body">
              <h2 class="pt-post-card__title"><%= post.title %></h2>

              <% if (post.excerpt) { %>
                <p class="pt-post-card__excerpt"><%= strip_html(post.excerpt).substring(0, 160) %>...</p>
              <% } %>

              <div class="pt-post-card__meta">
                <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>">
                  <%= date(post.date, 'YYYY-MM-DD') %>
                </time>

                <% if (theme.post.reading_time) { %>
                  <span class="pt-post-card__reading-time">
                    ~<%= Math.max(1, Math.ceil(strip_html(post.content).length / 500)) %> min read
                  </span>
                <% } %>

                <% if (post.categories && post.categories.length) { %>
                  <span class="pt-post-card__categories">
                    <% post.categories.each(function(cat){ %>
                      <span class="pt-tag pt-tag--category"><%= cat.name %></span>
                    <% }) %>
                  </span>
                <% } %>
              </div>

              <% if (post.tags && post.tags.length) { %>
                <div class="pt-post-card__tags">
                  <% post.tags.each(function(tag){ %>
                    <span class="pt-tag"><%= tag.name %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </a>
        </article>
      <% }) %>
    </div>

    <!-- Pagination -->
    <%- partial('_partial/pagination', { page: page }) %>
  </div>

  <!-- Sidebar -->
  <aside class="pt-layout__sidebar">
    <%- partial('_partial/sidebar', { config: config, theme: theme }) %>
  </aside>
</div>
