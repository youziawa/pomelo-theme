// ===================================
// Pomelo Theme — Acrylic Material System
// ===================================
@import '_variables'

// ── Core Acrylic Surface ──
// Base mixin: all acrylic surfaces share this
acrylic-base($blur = $blur-card, $opacity = 0.80, $bg = rgba(22, 22, 35, $opacity), $border = $acrylic-border)
  background: $bg
  backdrop-filter: blur($blur) saturate($saturate-acrylic)
  -webkit-backdrop-filter: blur($blur) saturate($saturate-acrylic)
  border: 1px solid $border

// ── Acrylic Depth Tiers ──
acrylic-card()
  acrylic-base($blur-card, 0.80)
  box-shadow: inset 0 1px 0 $acrylic-highlight-top, $shadow-card

acrylic-card-interactive()
  acrylic-card()
  transition: transform $transition-base, box-shadow $transition-base, border-color $transition-base
  &:hover
    transform: translateY(-2px)
    box-shadow: inset 0 1px 0 $acrylic-highlight-top, $shadow-card-hover
    border-color: rgba($clr-primary, 0.15)

acrylic-header()
  acrylic-base($blur-header, 0.70, rgba(18, 18, 30, 0.70), $acrylic-border-header)
  // Top edge lighter, bottom darker — glass thickness illusion
  border-top: 1px solid $acrylic-border-header
  border-bottom: 1px solid rgba(0, 0, 0, 0.25)
  box-shadow: $shadow-header

acrylic-drawer()
  acrylic-base($blur-drawer, 0.82, rgba(18, 18, 30, 0.82), $acrylic-border-header)
  box-shadow: 0 0 48px rgba(0, 0, 0, 0.5)

acrylic-modal()
  acrylic-base($blur-modal, 0.88, rgba(8, 8, 15, 0.88), $acrylic-border-modal)
  box-shadow: $shadow-modal

// ── Acrylic Tinting (low-opacity color overlays) ──
acrylic-tint-cyan()
  position: relative
  &::before
    content: ""
    position: absolute
    inset: 0
    background: $acrylic-cyan-tint
    pointer-events: none
    border-radius: inherit

acrylic-tint-magenta()
  position: relative
  &::before
    content: ""
    position: absolute
    inset: 0
    background: $acrylic-magenta-tint
    pointer-events: none
    border-radius: inherit

acrylic-tint-terminal()
  position: relative
  &::before
    content: ""
    position: absolute
    inset: 0
    background: $acrylic-green-tint
    pointer-events: none
    border-radius: inherit

// ── Noise Texture Overlay ──
// Uses inline SVG data URI for zero-network-request noise
acrylic-noise()
  &::after
    content: ""
    position: absolute
    inset: 0
    opacity: 0.03
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E")
    background-repeat: repeat
    pointer-events: none
    border-radius: inherit

// ── Edge Highlight (top-light, bottom-dark glass illusion) ──
acrylic-edge-highlight()
  border-top: 1px solid rgba(255, 255, 255, 0.08)
  border-left: 1px solid rgba(255, 255, 255, 0.05)
  border-right: 1px solid rgba(255, 255, 255, 0.05)
  border-bottom: 1px solid rgba(0, 0, 0, 0.3)

// ── Full Acrylic Card (with noise + edge highlight) ──
acrylic-card-full()
  acrylic-card()
  acrylic-edge-highlight()
  position: relative
  acrylic-noise()

// ── Acrylic Fallback (no backdrop-filter, for low-end devices) ──
acrylic-fallback()
  background: rgba(18, 18, 30, 0.92)
  border: 1px solid $acrylic-border

// Apply fallback when glassmorphism is disabled or device can't handle it
.glass-disabled
  .pt-glass
    acrylic-fallback()

// ── CRT Scanline Overlay ──
crt-scanlines($opacity = 0.03)
  position: relative
  &::before
    content: ""
    position: absolute
    inset: 0
    pointer-events: none
    z-index: $z-modal
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, $opacity) 2px,
      rgba(0, 0, 0, $opacity) 4px
    )
    border-radius: inherit

// ── Grid Background ──
grid-background($size = 40px, $opacity = 0.03)
  background-image:
    linear-gradient(rgba(0, 255, 200, $opacity) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 200, $opacity) 1px, transparent 1px)
  background-size: $size $size
