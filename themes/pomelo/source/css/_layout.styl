// ===================================
// Pomelo Theme — Layout System
// ===================================
@import '_variables'
@import '_acrylic'

// ── Site Wrapper ──
.pt-site
  display: flex
  flex-direction: column
  min-height: 100vh

// ── Main Content Area ──
.pt-main
  flex: 1
  container()
  padding-top: "calc(%s + %s)" % ($header-height $space-xl)
  padding-bottom: $space-3xl

// ── Two-Column Layout (main + sidebar) ──
.pt-layout
  display: grid
  grid-template-columns: minmax(0, 720px) $sidebar-width
  gap: $space-2xl                // 48px gap
  margin-top: $space-lg

  &--right-sidebar
    grid-template-columns: minmax(0, 720px) $sidebar-width

  &--left-sidebar
    grid-template-columns: $sidebar-width minmax(0, 720px)

.pt-layout__content
  min-width: 0
  width: 100%

.pt-layout__sidebar
  min-width: 0
  overflow: hidden
  width: $sidebar-width
  max-width: $sidebar-width
  flex-shrink: 0

// ── Page Header (archive/category/tag title) ──
.pt-page-header
  margin-bottom: $space-xl
  text-align: center

  &__title
    font-size: $font-scale-lg
    font-weight: $font-wt-bold
    neon-text($clr-primary)

  &__subtitle
    font-size: $font-scale-sm
    color: $clr-text-secondary
    margin-top: $space-xs

// ── Card Grid ──
.pt-card-grid
  display: grid
  grid-template-columns: 1fr
  gap: $space-lg
  width: 100%

