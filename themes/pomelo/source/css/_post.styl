// ===================================
// Pomelo Theme — Post Styles (article & card)
// ===================================
@import '_variables'
@import '_acrylic'

// ── Post Card (on homepage) ──
.pt-post-card
  border-radius: $radius-lg
  overflow: hidden
  acrylic-card()
  acrylic-edge-highlight()
  position: relative
  acrylic-noise()
  transition: transform $transition-base, box-shadow $transition-base, border-color $transition-base

  &:hover
    transform: translateY(-3px)
    box-shadow: $shadow-card-hover
    border-color: rgba($clr-primary, 0.15)

    .pt-post-card__title
      color: $clr-primary

  &__link
    display: block
    color: inherit
    text-decoration: none
    &:hover
      text-decoration: none

  &__cover
    width: 100%
    height: 200px
    overflow: hidden

    img
      width: 100%
      height: 100%
      object-fit: cover
      transition: transform $transition-slow
      &:hover
        transform: scale(1.03)

  &__body
    padding: $space-lg

  &__title
    font-size: $font-scale-md
    font-weight: $font-wt-semibold
    line-height: $line-height-heading
    margin-bottom: $space-sm
    transition: color $transition-fast
    color: $clr-text

  &__excerpt
    font-size: $font-scale-sm
    color: $clr-text-secondary
    line-height: $line-height-body
    margin-bottom: $space-md
    display: -webkit-box
    -webkit-line-clamp: 2
    -webkit-box-orient: vertical
    overflow: hidden

  &__meta
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: $space-sm
    font-size: $font-scale-xs
    color: $clr-text-secondary
    margin-bottom: $space-sm

  &__reading-time
    &::before
      content: "·"
      margin-right: $space-xs

  &__tags
    display: flex
    flex-wrap: wrap
    gap: $space-xs

// ── Post Detail (single post page) ──
.pt-post--single
  content-width()

.pt-post__header
  text-align: center
  margin-bottom: $space-xl

.pt-post__title
  font-size: $font-scale-lg
  font-weight: $font-wt-bold
  line-height: $line-height-heading
  margin-bottom: $space-md
  neon-text($clr-primary)

.pt-post__meta
  display: flex
  flex-wrap: wrap
  justify-content: center
  align-items: center
  gap: $space-md
  font-size: $font-scale-sm
  color: $clr-text-secondary
  margin-bottom: $space-md

  span
    flex-center()
    gap: $space-xs

.pt-icon
  flex-shrink: 0

.pt-post__updated
  color: $clr-text-disabled
  font-style: italic

.pt-post__categories
  display: flex
  justify-content: center
  gap: $space-xs
  flex-wrap: wrap

// ── Table of Contents ──
.pt-toc
  margin: $space-lg 0
  padding: $space-md $space-lg
  border-radius: $radius-lg
  acrylic-card()

  &__toggle
    font-weight: $font-wt-semibold
    cursor: pointer
    color: $clr-primary
    list-style: none
    &::-webkit-details-marker
      display: none

  &__nav
    margin-top: $space-sm
    font-size: $font-scale-sm
    max-height: 50vh
    overflow-y: auto

    ol
      list-style: decimal
      padding-left: $space-lg
      ol
        padding-left: $space-md

    li
      margin-bottom: $space-xs

    a
      color: $clr-text-secondary
      text-decoration: none
      &:hover
        color: $clr-primary

// ── Tags at bottom ──
.pt-post__tags
  display: flex
  flex-wrap: wrap
  gap: $space-xs
  margin: $space-xl 0

// ── Copyright Notice ──
.pt-post__copyright
  margin: $space-xl 0
  padding: $space-md $space-lg
  border-radius: $radius-lg
  font-size: $font-scale-sm
  color: $clr-text-secondary

  strong
    color: $clr-text

  a
    word-break: break-all

// ── Prev / Next Navigation ──
.pt-post__nav
  display: grid
  grid-template-columns: 1fr 1fr
  gap: $space-md
  margin: $space-xl 0
  padding-top: $space-xl
  border-top: 1px solid rgba(255, 255, 255, 0.06)

  &-prev, &-next
    padding: $space-md
    border-radius: $radius-lg
    acrylic-card()
    text-decoration: none
    transition: all $transition-fast

    &:hover
      border-color: rgba($clr-primary, 0.2)
      text-decoration: none

  &-next
    text-align: right
    grid-column: 2

  &-prev
    grid-column: 1

  &-label
    display: block
    font-size: $font-scale-xs
    color: $clr-text-secondary
    margin-bottom: $space-xs

  &-title
    font-size: $font-scale-sm
    color: $clr-text
    text-ellipsis()
