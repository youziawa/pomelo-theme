// ===================================
// Pomelo Theme — Design Tokens
// ===================================

// ── Color Palette ──
$clr-primary       = #00FFC8  // neon cyan
$clr-accent        = #FF0088  // magenta
$clr-highlight     = #FFD700  // gold
$clr-terminal      = #00FF41  // terminal green
$clr-warning       = #FF6B35  // orange
$clr-info          = #5BC0EB  // sky blue

$clr-bg            = #08080F  // deep base
$clr-bg-elevated   = #0E0E18  // slightly lifted
$clr-text          = #D8D8E0  // primary text
$clr-text-secondary = #9A9AB0 // secondary text
$clr-text-disabled  = #5A5A6E // disabled/placeholder

// ── Acrylic Tint Colors (rgba for glass overlays) ──
$acrylic-bg         = rgba(22, 22, 35, 0.80)
$acrylic-bg-header  = rgba(18, 18, 30, 0.82)
$acrylic-bg-modal   = rgba(8, 8, 15, 0.92)
$acrylic-cyan-tint  = rgba(0, 255, 200, 0.06)
$acrylic-magenta-tint = rgba(255, 0, 136, 0.06)
$acrylic-green-tint = rgba(0, 255, 65, 0.03)
$acrylic-border     = rgba(255, 255, 255, 0.10)
$acrylic-border-header = rgba(255, 255, 255, 0.10)
$acrylic-border-modal  = rgba(255, 255, 255, 0.14)
$acrylic-highlight-top = rgba(255, 255, 255, 0.08)

// ── Typography Scale (1.25 ratio) ──
$font-base        = 16px
$font-scale-xs    = 0.75rem   // 12px — tags, footnotes
$font-scale-sm    = 0.875rem  // 14px — meta, secondary
$font-scale-base  = 1rem      // 16px — body
$font-scale-md    = 1.25rem   // 20px — subheading
$font-scale-lg    = 1.75rem   // 28px — article title
$font-scale-xl    = 2.5rem    // 40px — hero

$font-body        = "PingFang SC", "Microsoft YaHei", "Noto Sans SC", "Hiragino Sans GB", sans-serif
$font-code        = "JetBrains Mono", "Fira Code", "Cascadia Code", "Consolas", monospace

$line-height-body = 1.8
$line-height-code = 1.6
$line-height-heading = 1.3

$font-wt-regular  = 400
$font-wt-medium   = 500
$font-wt-semibold = 600
$font-wt-bold     = 700

// ── Spacing Scale (4px grid) ──
$space-xs   = 4px
$space-sm   = 8px
$space-md   = 16px
$space-lg   = 24px
$space-xl   = 32px
$space-2xl  = 48px
$space-3xl  = 64px

// ── Border Radius ──
$radius-sm   = 4px
$radius-md   = 8px
$radius-lg   = 12px
$radius-xl   = 16px
$radius-full = 50%

// ── Z-Index Scale ──
$z-base       = 0
$z-card       = 10
$z-header     = 20
$z-drawer     = 30
$z-modal      = 40
$z-toast      = 50
$z-cursor     = 100

// ── Acrylic Blur Values ──
$blur-card   = 20px
$blur-header = 28px
$blur-drawer = 36px
$blur-modal  = 48px

$saturate-acrylic = 130%

// ── Neon Glow Presets ──
$glow-cyan-sm   = 0 0 6px rgba(0, 255, 200, 0.3)
$glow-cyan-md   = 0 0 10px rgba(0, 255, 200, 0.25), 0 0 40px rgba(0, 255, 200, 0.1)
$glow-cyan-lg   = 0 0 15px rgba(0, 255, 200, 0.3), 0 0 60px rgba(0, 255, 200, 0.15), 0 0 100px rgba(0, 255, 200, 0.05)
$glow-magenta-sm = 0 0 6px rgba(255, 0, 136, 0.3)
$glow-magenta-md = 0 0 10px rgba(255, 0, 136, 0.25), 0 0 40px rgba(255, 0, 136, 0.1)

// ── Shadows ──
$shadow-card    = 0 4px 24px rgba(0, 0, 0, 0.3)
$shadow-card-hover = 0 8px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 255, 200, 0.1)
$shadow-header  = 0 1px 32px rgba(0, 0, 0, 0.4)
$shadow-modal   = 0 16px 64px rgba(0, 0, 0, 0.6)

// ── Transitions ──
$transition-fast    = 150ms ease
$transition-base    = 250ms ease
$transition-slow    = 400ms ease
$transition-spring  = 400ms cubic-bezier(0.34, 1.56, 0.64, 1)

// ── Layout ──
$max-width-content  = 720px
$max-width-site     = 1320px
$sidebar-width      = 300px
$header-height      = 56px

// ── Breakpoints ──
$bp-mobile   = 640px
$bp-tablet   = 768px
$bp-desktop  = 1024px
$bp-wide     = 1280px
